from __future__ import annotations
from pathlib import Path
import pandas as pd


def _num(df: pd.DataFrame, col: str) -> pd.Series:
    return pd.to_numeric(df[col], errors='coerce').fillna(0.0) if col in df.columns else pd.Series([0.0] * len(df), index=df.index)


def run_portfolio_greeks(positions_file: str = 'outputs/paper_open_positions.csv') -> pd.DataFrame:
    path = Path(positions_file)
    df = pd.read_csv(path) if path.exists() and path.stat().st_size > 0 else pd.DataFrame()
    if not df.empty and 'status' in df.columns:
        df = df[df['status'].astype(str).str.lower().eq('open')]
    qty = _num(df, 'quantity') if not df.empty else pd.Series(dtype=float)
    for greek in ['delta','gamma','vega','theta']:
        if not df.empty:
            df[f'position_{greek}'] = _num(df, greek) * qty
    total = pd.DataFrame([{f'net_{greek}': df[f'position_{greek}'].sum() if not df.empty else 0.0 for greek in ['delta','gamma','vega','theta']}])
    by_expiry = df.groupby('expiry', as_index=False)[['position_delta','position_gamma','position_vega','position_theta']].sum() if not df.empty and 'expiry' in df.columns else pd.DataFrame()
    by_type = df.groupby('option_type', as_index=False)[['position_delta','position_gamma','position_vega','position_theta']].sum() if not df.empty and 'option_type' in df.columns else pd.DataFrame()
    Path('outputs').mkdir(exist_ok=True)
    total.to_csv('outputs/portfolio_greeks.csv', index=False)
    by_expiry.to_csv('outputs/portfolio_greeks_by_expiry.csv', index=False)
    by_type.to_csv('outputs/portfolio_greeks_by_type.csv', index=False)
    print('Portfolio Greeks complete.')
    return total


if __name__ == '__main__':
    run_portfolio_greeks()
